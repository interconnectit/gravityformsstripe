    --gform-admin-transition-hover: all 0.15s ease;
    --gform-admin-transition-hover-slow: color 300ms ease-in-out, background-color 300ms ease-in-out, border-color 300ms ease-in-out;
    --gform-admin-transition-color: color 0.15s ease;
    --gform-admin-transition-dropdown: opacity 0.15s ease;
    --gform-admin-transition-button: transform 300ms ease, box-shadow 300ms ease, background-color 300ms ease;
    --gform-admin-transition-inputs: box-shadow 0.15s ease, background-color 0.15s ease;
    --gform-admin-transition-toggles: left 0.25s ease;
    --gform-admin-transition-cl-button-focus: border-color 200ms ease-in-out, box-shadow 200ms ease-in-out;
    --gform-admin-transition-cl-flyout-reveal: opacity 190ms ease-in-out, transform 190ms ease-in-out;
