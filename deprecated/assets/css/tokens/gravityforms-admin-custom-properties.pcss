:root {
    --gform-admin-box-shadow-micro: 0 1px 4px rgba(18, 25, 97, 0.0779552);
    --gform-admin-box-shadow-datepicker: 0 0.125rem 0.75rem rgba(28, 31, 63, 0.09);
    --gform-admin-box-shadow-popup: 0 0 1px rgba(18, 25, 97, 0.24), 0 24px 24px rgba(18, 25, 97, 0.03), 0 2px 2px rgba(18, 25, 97, 0.03), 0 4px 4px rgba(18, 25, 97, 0.03), 0 8px 8px rgba(18, 25, 97, 0.03), 0 16px 16px rgba(18, 25, 97, 0.03);
    --gform-admin-box-shadow-toggle: 0 3px 8px rgba(18, 25, 97, 0.15), 0 1px 1px rgba(18, 25, 97, 0.16), 0 2px 1px rgba(18, 25, 97, 0.04);
    --gform-admin-box-shadow-mega: 0 24px 24px rgba(18, 25, 97, 0.03), 0 2px 2px rgba(18, 25, 97, 0.03), 0 4px 4px rgba(18, 25, 97, 0.03), 0 8px 8px rgba(18, 25, 97, 0.03), 0 16px 16px rgba(18, 25, 97, 0.03);
    --gform-admin-box-shadow-focus-light: 0 0 0 1px var(--gform-admin-color-focus);
    --gform-admin-box-shadow-focus: 0 0 0 2px var(--gform-admin-color-focus);
    --gform-admin-box-shadow-focus-sm: 0 1px 2px rgba(0, 0, 0, 0.05), 0 0 0 2px var(--gform-admin-color-white-lilac);
    --gform-admin-box-shadow-focus-state: 0 1px 2px rgba(0, 0, 0, 0.05), 0 0 0 2px var(--gform-admin-color-focus);
    --gform-admin-box-shadow-button: 0 1px 2px rgba(0, 0, 0, 0.05);
    --gform-admin-box-shadow-small: var(--gform-admin-box-shadow-datepicker);
    --gform-admin-box-shadow-input-focus: 0 0.125rem 0.0675rem rgba(28, 31, 63, 0.0634624), 0 0 0 2px var(--gform-admin-color-focus);
    --gform-admin-box-shadow-input-hover: 0 0.25rem 0.25rem rgba(18, 25, 97, 0.0405344);
    --gform-admin-box-shadow-input-error-focus: 0 0 0 2px var(--gform-admin-color-background-red), 0 1px 2px 0 rgba(16, 24, 40, 0.05);
    --gform-admin-box-shadow-outline-light: 0 2px 2px rgba(58, 58, 87, 0.0596411);
    --gform-admin-box-shadow-outline-light-hover: 0 4px 2px rgba(58, 58, 87, 0.1);
    --gform-admin-box-shadow-outline-light-hover-alt: 0 2px 2px rgba(58, 58, 87, 0.0796);
    --gform-admin-box-shadow-uber: 0 -10px 65px rgba(18, 25, 97, 0.09), 0 30px 30px rgba(18, 25, 97, 0.07), 0 15px 15px rgba(18, 25, 97, 0.06), 0 10px 8px rgba(18, 25, 97, 0.05), 0 4px 4px rgba(18, 25, 97, 0.04), 0 2px 2px rgba(18, 25, 97, 0.03);
    --gform-admin-box-shadow-super: 0 3px 8px rgba(18, 25, 97, 0.15), 0 1px 1px rgba(18, 25, 97, 0.16), 0 2px 1px rgba(18, 25, 97, 0.04);
    --gform-admin-box-shadow-midnight: 0 0 0 rgba(18, 25, 97, 0.05), 0 2px 5px rgba(18, 25, 97, 0.1), 0 1px 1px rgba(18, 25, 97, 0.15);
